{
  "name": "kothi",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "dev:api": "sst dev --stage dev",
    "build": "pnpm --filter web build",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "lint": "biome ci .",
    "format": "biome format --write .",
    "test": "vitest run",
    "check": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "sst": "^3.5.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
