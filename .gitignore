# ── Dependencies ──────────────────────────────────────────
node_modules/

# ── Build output ──────────────────────────────────────────
dist/
build/

# ── TypeScript incremental build cache ────────────────────
*.tsbuildinfo
tsconfig.tsbuildinfo

# ── Environment variables (never commit secrets) ──────────
.env
.env.*
!.env.example

# ── Drizzle generated snapshots & migrations (optional) ───
# Keep SQL migrations in git, but ignore generated meta snapshots
drizzle/meta/*.json

# ── Logs ──────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/

# ── Test coverage ─────────────────────────────────────────
coverage/
.nyc_output/

# ── OS files ──────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor / IDE ──────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Package manager locks (keep package-lock.json) ────────
yarn.lock
pnpm-lock.yaml
